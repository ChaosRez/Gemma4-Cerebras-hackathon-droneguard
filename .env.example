# Copy this file to .env for local development.
# Replay mode works without credentials; live and refresh modes require CEREBRAS_API_KEY.

CEREBRAS_API_KEY=
DRONEGUARD_MODEL=gemma-4-31b
CEREBRAS_CHAT_COMPLETIONS_URL=https://api.cerebras.ai/v1/chat/completions
DRONEGUARD_AGENT_RUNTIME=pydantic_ai

# Structured text agents use Pydantic AI's Cerebras adapter.
# Multimodal Vision requests continue to use the raw Cerebras Chat Completions client.

# Optional Arize Phoenix tracing for live Pydantic AI runs.
PHOENIX_TRACING=true
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006
PHOENIX_PROJECT_NAME=droneguard-multiverse

# Optional project-owned secrets for future integrations.
DRONEGUARD_API_TOKEN=
DRONEGUARD_CACHE_SECRET=
